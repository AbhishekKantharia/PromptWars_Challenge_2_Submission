rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Quiz scores (leaderboard)
    match /quizScores/{scoreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(request.resource.data.userId);
    }

    // User quiz progress
    match /userProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Chat history
    match /chatHistory/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Checklist progress
    match /checklistProgress/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Anonymous access for public data (if needed)
    match /publicData/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}